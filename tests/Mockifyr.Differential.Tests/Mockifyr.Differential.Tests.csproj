<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <!-- In-memory admin HTTP host for the G7b differential. -->
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <!-- Real PostgreSQL container for the G16c persistence differential. -->
    <PackageReference Include="Testcontainers.PostgreSql" />
    <!-- Real Redis container for the G16d persistence differential. -->
    <PackageReference Include="Testcontainers.Redis" />
    <!-- gRPC client + codegen for the G13 differential. -->
    <PackageReference Include="Grpc.Net.Client" />
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Grpc.Tools" PrivateAssets="all" />
  </ItemGroup>

  <!-- WebApplicationFactory needs the ASP.NET shared framework in this (non-web) test project. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\harness\Mockifyr.Differential.Harness\Mockifyr.Differential.Harness.csproj" />
    <!-- The admin host under test (exposes `Program` for WebApplicationFactory). -->
    <ProjectReference Include="..\..\src\Mockifyr.Server\Mockifyr.Server.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

  <!-- gRPC client codegen from the test proto (G13); the compiled descriptor (greeter.dsc) is a
       committed fixture, copied to output for mounting into the oracle and Mockifyr's grpc dir. -->
  <ItemGroup>
    <Protobuf Include="Protos\greeter.proto" GrpcServices="Client" />
    <None Include="Protos\greeter.dsc" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
