<Project>

  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup>
    <!-- CQRS mediator (management path only — see docs/decisions/0005) -->
    <PackageVersion Include="Mediant" Version="1.0.0-rc.3" />
    <!-- JSONPath: Newtonsoft's dialect is the closest .NET proxy for WireMock's Jayway JsonPath
         (accepts `[?(@.x=='y')]`-style filters). Used only inside Mockifyr.Matching. -->
    <PackageVersion Include="Newtonsoft.Json" Version="13.0.3" />
    <!-- JSON Schema validation for matchesJsonSchema (G1h). json-everything's JsonSchema.Net is the
         MIT-licensed .NET validator with Draft 6/7/2019-09/2020-12 support. Used only inside
         Mockifyr.Matching. -->
    <PackageVersion Include="JsonSchema.Net" Version="9.2.2" />
  </ItemGroup>

  <ItemGroup Label="Testing / harness">
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageVersion Include="xunit" Version="2.9.2" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="2.8.2" />
    <!-- Differential harness: runs the real Java WireMock oracle in a container. -->
    <PackageVersion Include="Testcontainers" Version="4.12.0" />
  </ItemGroup>

</Project>
